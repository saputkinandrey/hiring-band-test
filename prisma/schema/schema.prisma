generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  brandId   String    @id
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users     User[]
  sessions  Session[]
  rawEvents RawEvent[]

  @@map("tenants")
}

model User {
  id           String    @id @default(cuid())
  brandId      String
  email        String
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant   Tenant    @relation(fields: [brandId], references: [brandId])
  sessions Session[]

  @@unique([brandId, email])
  @@index([brandId])
  @@map("users")
}

model Session {
  id        String    @id @default(cuid())
  brandId   String
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant Tenant @relation(fields: [brandId], references: [brandId])
  user   User   @relation(fields: [userId], references: [id])

  @@index([brandId])
  @@index([userId])
  @@index([tokenHash])
  @@map("sessions")
}

enum CallbackSource {
  psp
  gsp
}

model RawEvent {
  id             String         @id @default(cuid())
  brandId        String
  source         CallbackSource
  provider       String
  idempotencyKey String
  payload        Json
  status         String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant Tenant @relation(fields: [brandId], references: [brandId])

  @@unique([brandId, source, provider, idempotencyKey])
  @@index([brandId])
  @@map("raw_events")
}
